# ---- Data (NEVER commit; 465MB raw / 52MB gz; graders supply the file at Stage 3) ----
data/
*.jsonl
*.jsonl.gz
*.json.gz

# ---- Precomputed artifacts (regenerated by build_artifacts.py) ----
# The small TF-IDF similarity model (IDF table + JD seed vectors; aggregate stats, no candidate
# data) IS committed so a clean Stage-3 checkout reproduces the hybrid scorer with no rebuild.
# Everything else here (dense matrices, indexes) stays out of git.
artifacts/*
!artifacts/sim_model.json
*.npy
*.npz
*.faiss
*.bin
*.pkl
*.joblib

# ---- Scratch outputs (the FINAL submission csv is committed via `git add -f outputs/<id>.csv`) ----
outputs/
!outputs/.gitkeep

# ---- Python ----
__pycache__/
*.py[cod]
.venv/
venv/
env/
.ipynb_checkpoints/

# ---- Secrets / env ----
.env
*.secret

# ---- macOS / Office temp litter ----
.DS_Store
~$*
*.tmp

# ---- Working / process docs: keep LOCAL, keep the public repo clean ----
# These stay on disk for our own continuity but are never pushed to GitHub.
# NOTE: .gitignore does NOT support inline comments; keep patterns on their own lines.
CONTEXT.md
docs/
# generated eval scratch: samples, gold labels, audit results
eval/_work/
eval/_work2/
eval/_work_top100/
*.local.md
